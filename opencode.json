{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "browserbase": {
      "type": "local",
      "command": ["npx", "-y", "@browserbasehq/mcp-server-browserbase"],
      "enabled": true,
      "environment": {
        "BROWSERBASE_API_KEY": "${BROWSERBASE_API_KEY}",
        "BROWSERBASE_PROJECT_ID": "${BROWSERBASE_PROJECT_ID}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "word": {
      "type": "local",
      "command": ["uvx", "--from", "office-word-mcp-server", "word_mcp_server.exe"]
    },
    "excel": {
      "type": "local",
      "command": ["uvx", "excel-mcp-server", "stdio"]
    },
    "powerpoint": {
      "type": "local",
      "command": ["uvx", "--from", "office-powerpoint-mcp-server", "ppt_mcp_server.exe"]
    },
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", "EquinoxIT"],
      "enabled": true
    },
    "atlassian-rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {},
      "enabled": true
    },
    "word-bridge": {
      "type": "local",
      "command": ["python", "C:/Users/nick.foard/.config/opencode/mcp-servers/word-bridge/word_mcp.py"],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3:4b": {
          "_launch": true,
          "name": "qwen3:4b"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
